# ─── Alpha Command Center — Environment Variables ───────────
#
# Copy this file to `.env.local` and fill in the values. Vercel
# production pulls the same set from the project settings page.
# Lines documented as (server) never ship to the client bundle.
# Lines prefixed NEXT_PUBLIC_ are exposed to the browser and must
# never contain secrets.

# ─── Database (required) ─────────────────────────────────────
# Neon Postgres connection string. Use the POOLED URL, not the
# direct one — serverless functions exhaust direct connections.
DATABASE_URL="postgresql://USER:PASS@HOST-pooler.c-X.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── Auth (required) ─────────────────────────────────────────
# Secret used to sign session cookies + reset tokens. 32+ bytes.
AUTH_SECRET="replace-with-at-least-32-random-bytes"
# Public origin used when generating password-reset / email links.
APP_URL="https://fu-corp-crm.vercel.app"

# ─── AI / Groq (required for /api/chat) ──────────────────────
# Groq API key — server-only. Never prefix with NEXT_PUBLIC_.
GROQ_API_KEY=""
# Optional model override. Defaults to llama-3.3-70b-versatile.
# GROQ_MODEL="llama-3.3-70b-versatile"

# ─── Email / Resend (optional — best effort) ─────────────────
# If unset, email sends become no-ops (logged once on startup).
RESEND_API_KEY=""
EMAIL_FROM="Alpha Command Center <noreply@your-domain.com>"

# ─── Inbound webhooks (recommended) ──────────────────────────
# HMAC secret verified on POST /api/webhook/lead and /api/webhook/ticket
# using the X-Webhook-Signature header. If unset, signature checks are
# skipped and a warning is logged — only acceptable for local dev.
LEAD_WEBHOOK_SECRET=""
# Comma-separated list of allowed CORS origins for inbound webhooks.
WEBHOOK_ALLOWED_ORIGINS="https://virtualcustomersolution.com,https://digitalpointllc.com,https://backup-solutions.vercel.app"

# ─── Push notifications (optional) ───────────────────────────
# Generate a VAPID keypair with `npx web-push generate-vapid-keys`.
# The public key is intentionally browser-exposed (Web Push spec).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# ─── Rate limiting (optional — falls back to in-memory) ──────
# Without these, the rate limiter uses a per-function-instance Map
# which is best-effort under horizontal scaling. For production,
# provision an Upstash Redis instance and paste the REST URL + token.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── File uploads (optional) ─────────────────────────────────
# Vercel Blob token. Without it, upload endpoints fall back to
# metadata-only (no actual file storage).
BLOB_READ_WRITE_TOKEN=""

# ─── Google Sheets sync (optional) ───────────────────────────
# Endpoint that receives lead sync webhooks (from Google Apps Script).
GOOGLE_SHEETS_WEBHOOK_URL=""

# ─── Gmail OAuth (optional — enables email integration) ──────
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Enable Gmail API + set redirect URI to /api/gmail/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://fu-corp-crm.vercel.app/api/gmail/callback"

# ─── Dev-only toggles ────────────────────────────────────────
# Show the demo-login quick-fill row on /login? Prod must NOT set this.
NEXT_PUBLIC_SHOW_DEMO_LOGINS="false"
# Enable Next.js bundle analyzer when running `npm run build`.
# ANALYZE="true"
