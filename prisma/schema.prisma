// FU Corp Elite CRM — Enterprise Database Schema
// FU Corp = Mother Company | VCS, BSL, DPL = Subsidiaries

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  PROJECT_MANAGER
  DEPT_HEAD
  TEAM_LEAD
  EMPLOYEE
}

enum Department {
  LEADERSHIP
  MARKETING
  DEV
  CREATIVE
  SUPPORT
  ADMIN
  SALES
  OPS
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  PROBATION
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ClientStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum LeadStatus {
  NEW
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  REMOTE
  LEAVE
}

// ─── Models ──────────────────────────────────────────

model Brand {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // VCS, BSL, DPL
  color     String
  website   String?
  parentId  String?  // "FU" for subsidiaries
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  clients   Client[]
  tasks     Task[]
  leads     Lead[]
  invoices  Invoice[]

  @@map("brands")
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  passwordHash   String
  firstName      String
  lastName       String
  phone          String?
  avatar         String?
  title          String?
  role           Role           @default(EMPLOYEE)
  department     Department?
  status         EmployeeStatus @default(ACTIVE)
  brandId        String?
  hireDate       DateTime?
  salary         Float?
  currency       String         @default("USD")
  skills         String[]       @default([])
  managerId      String?
  isActive       Boolean        @default(true)
  lastLogin      DateTime?
  twoFactorEnabled Boolean      @default(false)
  language       String         @default("en")
  timezone       String         @default("Asia/Karachi")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  brand          Brand?         @relation(fields: [brandId], references: [id])
  manager        User?          @relation("ManagerRelation", fields: [managerId], references: [id])
  subordinates   User[]         @relation("ManagerRelation")

  assignedTasks  Task[]         @relation("TaskAssignee")
  createdTasks   Task[]         @relation("TaskCreator")
  comments       Comment[]
  notifications  Notification[]
  attendance     Attendance[]
  auditLogs      AuditLog[]
  notes          Note[]         @relation("NoteAuthor")
  attachments    Attachment[]

  @@map("users")
}

model Client {
  id           String       @id @default(cuid())
  companyName  String
  contactName  String
  email        String
  phone        String?
  country      String?
  countryFlag  String?
  website      String?
  source       String?
  status       ClientStatus @default(ACTIVE)
  healthScore     Int          @default(80)
  mrr             Float        @default(0)
  brandId         String
  services        String[]     @default([])
  lastContactDate DateTime?
  nextFollowUp    DateTime?
  accountManagerId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  brand           Brand        @relation(fields: [brandId], references: [id])
  invoices        Invoice[]
  notes           Note[]
  tasks           Task[]       @relation("ClientTasks")
  attachments     Attachment[] @relation("ClientAttachments")
  feedback        CustomerFeedback[]

  @@map("clients")
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  priority     Priority   @default(MEDIUM)
  department   Department?
  assigneeId   String?
  creatorId    String
  clientId     String?
  brandId      String?
  dueDate      DateTime?
  completedAt  DateTime?
  timeSpent    Float      @default(0)
  order        Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignee     User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator      User       @relation("TaskCreator", fields: [creatorId], references: [id])
  client       Client?    @relation("ClientTasks", fields: [clientId], references: [id])
  brand        Brand?     @relation(fields: [brandId], references: [id])
  comments     Comment[]
  attachments  Attachment[] @relation("TaskAttachments")

  @@map("tasks")
}

model Lead {
  id           String     @id @default(cuid())
  companyName  String
  contactName  String
  email        String?
  phone        String?
  country      String?
  countryFlag  String?
  services     String[]   @default([])
  source       String?
  status       LeadStatus @default(NEW)
  value        Float      @default(0)
  probability  Int        @default(50)
  salesRepId   String?
  brandId      String?
  expectedClose   DateTime?
  lastContactDate DateTime?
  nextContactDate DateTime?
  nextAction      String?
  notes           String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  brand        Brand?     @relation(fields: [brandId], references: [id])

  @@map("leads")
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique
  clientId    String
  brandId     String
  items       Json          // Array of { description, quantity, rate }
  subtotal    Float
  tax         Float         @default(0)
  total       Float
  status      InvoiceStatus @default(DRAFT)
  issueDate   DateTime
  dueDate     DateTime
  paidDate    DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client      Client        @relation(fields: [clientId], references: [id])
  brand       Brand         @relation(fields: [brandId], references: [id])

  @@map("invoices")
}

model Attendance {
  id          String           @id @default(cuid())
  userId      String
  date        DateTime         @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  status      AttendanceStatus @default(PRESENT)
  hoursWorked Float            @default(0)
  notes       String?
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("attendance")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  taskId    String?
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@map("comments")
}

model Note {
  id        String   @id @default(cuid())
  content   String
  clientId  String?
  authorId  String
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author    User     @relation("NoteAuthor", fields: [authorId], references: [id])

  @@map("notes")
}

model Attachment {
  id           String   @id @default(cuid())
  filename     String
  url          String
  mimeType     String?
  size         Int?
  taskId       String?
  clientId     String?
  uploadedById String
  createdAt    DateTime @default(now())

  task         Task?    @relation("TaskAttachments", fields: [taskId], references: [id], onDelete: Cascade)
  client       Client?  @relation("ClientAttachments", fields: [clientId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  @@map("attachments")
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String
  userId    String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // CREATE, UPDATE, DELETE
  entity    String   // User, Client, Task, Invoice, etc.
  entityId  String
  userId    String
  changes   Json?    // { field: { old, new } }
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@map("sessions")
}

model CustomerFeedback {
  id         String    @id @default(cuid())
  clientId   String
  type       String    // COMPLAINT, PRAISE, SUGGESTION
  status     String    @default("OPEN") // OPEN, RESOLVED, UNRESOLVED
  message    String
  response   String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("customer_feedback")
}
